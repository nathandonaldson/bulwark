# Copy to .env and fill in your values. Never commit the real .env —
# it's already in .gitignore.
#
# All env vars are optional. See spec/contracts/env_config.yaml for the
# canonical list. v2 is detection-only — ADR-031 removed BULWARK_LLM_MODE,
# BULWARK_API_KEY, BULWARK_BASE_URL, BULWARK_ANALYZE_MODEL, and
# BULWARK_EXECUTE_MODEL in v2.0.0. Bulwark never calls an LLM.

# ── Bearer auth token for mutating + judge-exposed endpoints (ADR-029) ────
# Required for non-loopback callers (e.g. Docker bridge IP). Generate any
# unguessable string; clients send it as `Authorization: Bearer <token>`.
# BULWARK_API_TOKEN=replace-me-with-a-long-random-string

# ── SSRF allowlist for webhook URLs (G-ENV-009) ───────────────────────────
# Comma-separated hostnames. If BULWARK_WEBHOOK_URL points at a
# private/LAN IP, list its hostname here or Bulwark's SSRF guard will
# reject it.
# BULWARK_ALLOWED_HOSTS=192.168.1.78

# ── Optional: HuggingFace token for gated detection models ────────────────
# Needed for PromptGuard-86M (Meta's gated classifier). Get one at
# https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...

# ── Optional: external webhook for BLOCKED-event alerts (ADR-026) ────────
# Set to a Slack / PagerDuty / Datadog webhook URL (or an internal alert
# router) to have Bulwark POST every BLOCKED event — canary leaks, guard
# hits, detection-model blocks — as fire-and-forget JSON. See README for
# payload shape. Leave unset for no external alerts.
# BULWARK_WEBHOOK_URL=https://hooks.slack.com/services/T0.../B0.../xxx

# ── Optional: override the host path for the bind-mounted config file ────
# Default: ~/.config/bulwark/bulwark-config.yaml
# BULWARK_CONFIG_PATH=/some/other/path/bulwark-config.yaml
